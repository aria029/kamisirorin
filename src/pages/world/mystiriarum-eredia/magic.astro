---
import MystiriarumPageLayout from "../../../layouts/MystiriarumPageLayout.astro";

const attributes = [
  "火",
  "水",
  "土",
  "風",
  "雷",
  "光",
  "闇",
  "無属性",
];

const magicRanks = [
  {
    name: "初級",
    chants: "1〜2唱節",
    description: "基礎的で、比較的短い詠唱によって発動する魔法。",
  },
  {
    name: "中級",
    chants: "3〜6唱節",
    description: "基礎魔法より高い出力や複雑な制御を必要とする魔法。",
  },
  {
    name: "上級",
    chants: "7〜10唱節",
    description: "熟練者向けの高威力・高難度魔法。",
  },
  {
    name: "最上級",
    chants: "11〜12唱節",
    description: "大規模な現象を起こす、極めて高度な魔法。",
  },
  {
    name: "極大",
    chants: "13唱節以上",
    description: "通常の魔法を大きく超える規模と詠唱を必要とする魔法。",
  },
];

const basicSpells = [
  {
    attribute: "火属性",
    name: "紅蓮の火球／ファイアーボール",
    chant: "爆ぜよ",
    type: "攻撃魔法",
    description: "魔法学校で教えられる、火属性の基礎攻撃魔法。",
  },
  {
    attribute: "火属性",
    name: "紅蓮の火壁／ファイアーウォール",
    chant: "設定中",
    type: "防御魔法",
    description: "魔法学校で教えられる、火属性の基礎防御魔法。",
  },
  {
    attribute: "水属性",
    name: "ウォーターボール",
    chant: "設定中",
    type: "攻撃魔法",
    description: "魔法学校で教えられる、水属性の基礎攻撃魔法。",
  },
  {
    attribute: "水属性",
    name: "ウォーターウォール",
    chant: "設定中",
    type: "防御魔法",
    description: "魔法学校で教えられる、水属性の基礎防御魔法。",
  },
  {
    attribute: "土属性",
    name: "ストーンボール",
    chant: "設定中",
    type: "攻撃魔法",
    description: "魔法学校で教えられる、土属性の基礎攻撃魔法。",
  },
  {
    attribute: "土属性",
    name: "ストーンウォール",
    chant: "設定中",
    type: "防御魔法",
    description: "魔法学校で教えられる、土属性の基礎防御魔法。",
  },
  {
    attribute: "風属性",
    name: "ウィンドボール",
    chant: "設定中",
    type: "攻撃魔法",
    description: "魔法学校で教えられる、風属性の基礎攻撃魔法。",
  },
  {
    attribute: "風属性",
    name: "ウィンドウォール",
    chant: "設定中",
    type: "防御魔法",
    description: "魔法学校で教えられる、風属性の基礎防御魔法。",
  },
  {
    attribute: "雷属性",
    name: "ライトニングボール",
    chant: "設定中",
    type: "攻撃魔法",
    description: "魔法学校で教えられる、雷属性の基礎攻撃魔法。",
  },
  {
    attribute: "雷属性",
    name: "ライトニングウォール",
    chant: "設定中",
    type: "防御魔法",
    description: "魔法学校で教えられる、雷属性の基礎防御魔法。",
  },
  {
    attribute: "光属性",
    name: "ライトボール",
    chant: "設定中",
    type: "攻撃魔法",
    description: "魔法学校で教えられる、光属性の基礎攻撃魔法。",
  },
  {
    attribute: "光属性",
    name: "ライトウォール",
