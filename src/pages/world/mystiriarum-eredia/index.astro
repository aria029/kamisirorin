---
const siteName = "神白 凛";

const worldSections = [
  {
    category: "OVERVIEW",
    title: "世界観",
    description:
      "ミスティリアルム・エレディアの成り立ちや、世界全体に関わる設定をまとめています。",
    link: "/world/mystiriarum-eredia/overview",
  },
  {
    category: "GEOGRAPHY",
    title: "地理と国家",
    description:
      "世界を構成する地域、国家、都市、土地などの地理情報をまとめています。",
    link: "/world/mystiriarum-eredia/geography",
  },
  {
    category: "LIFE & CULTURE",
    title: "社会と生活・娯楽",
    description:
      "人々の暮らし、文化、教育、食事、交通、仕事、娯楽などをまとめています。",
    link: "/world/mystiriarum-eredia/life",
  },
  {
    category: "ORGANIZATION & SYSTEM",
    title: "組織・制度",
    description:
      "騎士団、ギルド、学校、教会、商会など、社会を支える組織や制度をまとめています。",
    link: "/world/mystiriarum-eredia/systems",
  },
  {
    category: "THREATS",
    title: "脅威",
    description:
      "魔物や外敵など、人々や世界に危険をもたらす存在についてまとめています。",
    link: "/world/mystiriarum-eredia/threats",
  },
  {
    category: "MAGIC",
    title: "魔法",
    description:
      "魔力、属性、詠唱、魔法の分類やランクなど、この世界の魔法体系をまとめています。",
    link: "/world/mystiriarum-eredia/magic",
  },
  {
    category: "GLOSSARY",
    title: "用語集",
    description:
      "地域名、国家名、組織名、魔法など、世界に登場する固有名詞をまとめています。",
    link: "/world/mystiriarum-eredia/glossary",
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="description"
      content="神白 凛が制作する世界観作品、ミスティリアルム・エレディアの設定資料ページです。"
    />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>ミスティリアルム・エレディア | 神白 凛</title>
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">{siteName}</a>

      <nav class="nav" aria-label="メインメニュー">
        <a href="/#profile">プロフィール</a>
        <a href="/#topics">トピック</a>
        <a href="/#youtube">YouTube</a>
        <a href="/#works">作品集</a>
        <a href="/#contact">コンタクト</a>
      </nav>
    </header>

    <main>
      <section class="world-hero">
        <div class="hero-decoration" aria-hidden="true">魔</div>

        <div class="hero-inner">
          <p class="hero-label">MYSTIRIARUM EREDIA</p>

          <h1>
            ミスティリアルム
            <span>・エレディア</span>
          </h1>

          <p class="hero-lead">
            魔法が存在する世界「ミスティリアルム・エレディア」の
            歴史、地理、文化、社会、魔法、用語などをまとめています。
          </p>

          <div class="hero-actions">
            <a class="button primary" href="#contents">
              設定資料を見る
            </a>

            <a class="button" href="/world">
              作品一覧へ戻る
            </a>
          </div>
        </div>
      </section>

      <section class="section introduction-section">
        <div class="section-heading">
          <p>ABOUT THIS WORLD</p>
          <h2>この世界について</h2>
        </div>

        <article class="introduction-card">
          <div class="introduction-content">
            <p class="small-label">WORLD INTRODUCTION</p>

            <h3>魔法と人々が共に生きる世界</h3>

            <p>
              ミスティリアルム・エレディアは、魔法が人々の暮らしや社会に
              深く根付いている世界です。
            </p>

            <p>
              このページでは、世界全体の成り立ちから、地域や国家、
              人々の生活、社会制度、脅威、魔法体系まで、
              物語の舞台となる世界の設定を項目ごとに掲載します。
            </p>
          </div>
        </article>
      </section>

      <section class="section" id="contents">
        <div class="section-heading">
          <p>WORLD DOCUMENTS</p>
          <h2>設定資料</h2>
        </div>

        <div class="contents-introduction">
          <p>
            閲覧したい項目を選択してください。
            各ページに、ミスティリアルム・エレディアの設定を分類して掲載します。
          </p>
        </div>

        <div class="contents-grid">
          {
            worldSections.map((section, index) => (
              <a class="content-card" href={section.link}>
                <div class="content-number" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </div>

                <div class="content-card-top">
                  <p>{section.category}</p>
                </div>

                <div class="content-card-main">
                  <h3>{section.title}</h3>
                  <p>{section.description}</p>
                </div>

                <div class="content-card-footer">
                  <span>{section.title}を見る</span>
                  <span aria-hidden="true">→</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section return-section">
        <div class="return-card">
          <div>
            <p class="small-label">BACK TO WORLD WORKS</p>

            <h2>ほかの世界観作品を見る</h2>

            <p>
              世界観・物語設定の作品一覧から、ほかの世界を確認できます。
            </p>
          </div>

          <a class="button primary" href="/world">
            作品一覧へ戻る
          </a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <p>© 神白 凛</p>
    </footer>
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Kaisei+Tokumin:wght@400;500;700;800&family=Yuji+Syuku&display=swap");

  :root {
    --bg: #fffafb;
    --bg-soft: #fff1f5;
    --paper: #ffffff;

    --line: rgba(238, 143, 170, 0.34);

    --sakura: #f3a9bd;
    --sakura-soft: #ffd6e1;
    --sakura-deep: #dd6f94;
    --sakura-strong: #f08aaa;

    --text: #3a2630;
    --muted: #7b5c68;
    --muted-light: #9b7d88;

    --shadow: rgba(179, 92, 119, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    margin: 0;
    font-family:
      "Kaisei Tokumin",
      "Yu Mincho",
      "Hiragino Mincho ProN",
      "Noto Serif JP",
      serif;
    color: var(--text);
    line-height: 1.8;
    background:
      radial-gradient(
        circle at 18% 8%,
        rgba(255, 198, 214, 0.72),
        transparent 34%
      ),
      radial-gradient(
        circle at 82% 4%,
        rgba(255, 224, 233, 0.85),
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 92%,
        rgba(243, 169, 189, 0.42),
        transparent 38%
      ),
      linear-gradient(
        180deg,
        #fffafb 0%,
        #fff4f7 48%,
        #fffefe 100%
      );
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(
        rgba(238, 143, 170, 0.08) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(238, 143, 170, 0.08) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
    mask-image: linear-gradient(
      to bottom,
      black,
      transparent 82%
    );
  }

  body::after {
    content: "✦ ✧ ✦";
    position: fixed;
    right: 5vw;
    bottom: 4vh;
    z-index: -1;
    pointer-events: none;
    color: rgba(240, 138, 170, 0.18);
    font-size: clamp(48px, 9vw, 120px);
    letter-spacing: 0.12em;
    transform: rotate(-8deg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 5vw;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 250, 251, 0.88);
    box-shadow: 0 10px 30px rgba(238, 143, 170, 0.08);
    backdrop-filter: blur(14px);
  }

  .logo {
    color: var(--sakura-deep);
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.14em;
  }

  .nav {
    display: flex;
    gap: 24px;
    font-size: 14px;
    letter-spacing: 0.12em;
  }

  .nav a {
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .nav a:hover {
    color: var(--sakura-deep);
  }

  main {
    overflow: hidden;
  }

  .world-hero {
    position: relative;
    min-height: 76vh;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 110px 5vw 90px;
    border-bottom: 1px solid var(--line);
  }

  .world-hero::before {
    content: "";
    position: absolute;
    width: min(700px, 76vw);
    aspect-ratio: 1;
    border: 1px solid rgba(240, 138, 170, 0.28);
    border-radius: 50%;
    background: rgba(255, 214, 225, 0.16);
    transform: rotate(18deg);
  }

  .world-hero::after {
    content: "";
    position: absolute;
    width: min(400px, 46vw);
    aspect-ratio: 1;
    border: 1px solid rgba(221, 111, 148, 0.26);
    background: rgba(255, 255, 255, 0.26);
    transform: rotate(45deg);
  }

  .hero-decoration {
    position: absolute;
    color: rgba(240, 138, 170, 0.11);
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(200px, 34vw, 450px);
    line-height: 1;
    user-select: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: min(1000px, 90vw);
    text-align: center;
  }

  .hero-label,
  .section-heading > p,
  .small-label {
    margin: 0;
    color: var(--sakura-deep);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 20px 0 24px;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(52px, 9vw, 108px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.06em;
    text-shadow: 0 8px 34px rgba(240, 138, 170, 0.18);
  }

  h1 span {
    white-space: nowrap;
  }

  .hero-lead {
    max-width: 760px;
    margin: 0 auto;
    color: var(--muted);
    font-size: 18px;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .button {
    min-width: 150px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 22px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--sakura-deep);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 12px 32px rgba(238, 143, 170, 0.12);
    font-weight: 700;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: var(--sakura-strong);
    background: #ffffff;
    box-shadow: 0 16px 40px rgba(238, 143, 170, 0.2);
  }

  .button.primary {
    color: #ffffff;
    border-color: transparent;
    background: linear-gradient(
      135deg,
      var(--sakura-strong),
      var(--sakura-deep)
    );
  }

  .section {
    width: min(1100px, 90vw);
    margin: 0 auto;
    padding: 110px 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 34px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--line);
  }

  .section-heading h2 {
    margin: 0;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(40px, 6vw, 76px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.08em;
  }

  .introduction-card,
  .return-card {
    border: 1px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(
        135deg,
        rgba(255, 214, 225, 0.72),
        transparent 46%
      ),
      rgba(255, 255, 255, 0.88);
    box-shadow: 0 24px 80px var(--shadow);
  }

  .introduction-card {
    padding: clamp(30px, 5vw, 58px);
  }

  .introduction-content {
    max-width: 850px;
  }

  .introduction-content h3 {
    margin: 10px 0 18px;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 400;
    line-height: 1.4;
  }

  .introduction-content > p {
    color: var(--muted);
  }

  .contents-introduction {
    margin-bottom: 28px;
    padding: 20px 24px;
    border: 1px solid rgba(221, 111, 148, 0.24);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.66);
  }

  .contents-introduction p {
    margin: 0;
    color: var(--muted);
  }

  .contents-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .content-card {
    position: relative;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(
        145deg,
        rgba(255, 198, 214, 0.74),
        transparent 48%
      ),
      rgba(255, 255, 255, 0.92);
    box-shadow: 0 22px 60px rgba(238, 143, 170, 0.12);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .content-card:hover {
    transform: translateY(-6px);
    border-color: rgba(221, 111, 148, 0.52);
    box-shadow: 0 30px 76px rgba(238, 143, 170, 0.22);
  }

  .content-number {
    position: absolute;
    right: 22px;
    bottom: 62px;
    color: rgba(221, 111, 148, 0.08);
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(100px, 13vw, 160px);
    line-height: 0.7;
    pointer-events: none;
  }

  .content-card-top {
    position: absolute;
    top: 24px;
    left: 28px;
    right: 28px;
  }

  .content-card-top p {
    margin: 0;
    color: var(--sakura-deep);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  .content-card-main {
    position: relative;
    z-index: 1;
  }

  .content-card-main h3 {
    margin: 0 0 14px;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: 34px;
    font-weight: 400;
    line-height: 1.4;
  }

  .content-card-main p {
    margin: 0;
    color: var(--muted);
  }

  .content-card-footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: 26px;
    padding-top: 15px;
    border-top: 1px solid rgba(238, 143, 170, 0.26);
    color: var(--sakura-deep);
    font-size: 14px;
    font-weight: 700;
  }

  .content-card-footer span:last-child {
    font-size: 22px;
    transition: transform 0.2s ease;
  }

  .content-card:hover .content-card-footer span:last-child {
    transform: translateX(5px);
  }

  .return-section {
    padding-top: 40px;
  }

  .return-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: clamp(30px, 5vw, 54px);
  }

  .return-card h2 {
    margin: 10px 0 18px;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 400;
    line-height: 1.4;
  }

  .return-card p {
    margin-bottom: 0;
    color: var(--muted);
  }

  .footer {
    padding: 32px 5vw;
    border-top: 1px solid var(--line);
    color: var(--muted-light);
    text-align: center;
    background: rgba(255, 250, 251, 0.7);
  }

  @media (max-width: 860px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 16px;
    }

    .nav {
      width: 100%;
      gap: 18px;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .world-hero {
      min-height: 68vh;
      place-items: end start;
    }

    .hero-inner {
      text-align: left;
    }

    .hero-actions {
      justify-content: flex-start;
    }

    .section-heading {
      display: block;
    }

    .section-heading h2 {
      margin-top: 8px;
    }

    .contents-grid {
      grid-template-columns: 1fr;
    }

    .return-card {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    .section {
      width: min(92vw, 1100px);
      padding: 82px 0;
    }

    h1 {
      font-size: clamp(44px, 13vw, 70px);
    }

    h1 span {
      white-space: normal;
    }

    .introduction-card,
    .return-card {
      padding: 26px 22px;
      border-radius: 22px;
    }

    .content-card {
      min-height: 280px;
      padding: 26px 22px;
      border-radius: 22px;
    }

    .content-card-top {
      top: 22px;
      left: 22px;
      right: 22px;
    }

    .content-card-main h3 {
      font-size: 30px;
    }

    .content-number {
      right: 14px;
      bottom: 66px;
      font-size: 110px;
    }
  }
</style>