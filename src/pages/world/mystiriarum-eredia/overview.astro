---
const siteName = "神白 凛";

const worldFeatures = [
  {
    number: "01",
    category: "MAGIC",
    title: "誰もが扱える魔法",
    text: "魔法は一部の特別な者だけが使える力ではなく、人々が生まれながらに持ち、誰もが扱える力として社会に浸透しています。",
  },
  {
    number: "02",
    category: "INFRASTRUCTURE",
    title: "暮らしを支える力",
    text: "魔法は戦闘だけでなく、生活、物流、医療、治安維持など、人々の暮らしを支えるインフラとして活用されています。",
  },
  {
    number: "03",
    category: "RESEARCH",
    title: "進み続ける魔法研究",
    text: "魔法の改良、古代魔法の調査、新しい魔法の開発など、世界各地で魔法に関する研究が続けられています。",
  },
  {
    number: "04",
    category: "DANGER",
    title: "文明の外に潜む脅威",
    text: "この世界には魔法を扱う魔物も存在し、文明の外縁や未知の領域には、常に不確定な脅威が潜んでいます。",
  },
];

const spoilerSections = [
  {
    category: "HUMANITY",
    title: "人類は二代目である",
    paragraphs: [
      "現在、この世界で暮らしている人類は二代目にあたります。",
      "初代の人類は数千年前に一度滅亡しました。文明を途絶えさせないため、この星を管理する神が必要最小限の干渉を行い、新たな人類を生み出しました。",
      "二代目の人類は長い年月をかけて新たな文明や文化、都市を築きましたが、初代人類の滅亡や、自分たちが二代目であるという事実を知りません。",
    ],
  },
  {
    category: "GODS",
    title: "世界を管理する神々",
    paragraphs: [
      "世界の外側には、それぞれの星を管理する十二柱の神々が存在しています。",
      "神々は担当する星の文明が途絶えないよう見守っていますが、人類はその存在を知りません。",
      "星への過度な干渉は禁じられており、文明を存続させるための必要最小限の介入だけが認められています。",
      "十二柱の神々は、王道十二星座をモチーフとしています。",
    ],
  },
  {
    category: "SUN & ENEMY",
    title: "太陽と外敵",
    paragraphs: [
      "この世界の太陽は、外敵の巣窟となっています。",
      "外敵は太陽光へ干渉し、その光に乗って太陽の光が届く星々へ移動します。各地へ降り立った外敵は、星の文明に災厄をもたらします。",
      "外敵の目的は太陽を完全に解放することです。しかし、太陽はすべての世界に不可欠であり、破壊するという選択は取れません。",
      "そのため神々は、太陽を破壊するのではなく、封印によって外敵を抑え込んでいます。",
    ],
  },
  {
    category: "KING OF GODS",
    title: "神々の王と太陽封印",
    paragraphs: [
      "太陽を抑える封印は強固ですが、周期的に弱まるため、定期的に更新しなければなりません。",
      "封印を更新する役目は、十二柱の中から選ばれる神々の王が担います。",
      "神々には順位があり、戦いによってランキングが変動します。最終的に一位となった神は、現在の王へ挑戦する資格を得ます。",
      "王を倒した神は新たな王となり、自身の星に加えて太陽の管理と封印の維持を任されます。",
    ],
  },
  {
    category: "HEAVENLY WAR",
    title: "天界大戦",
    paragraphs: [
      "神々の王を選ぶために行われる儀式が、天界大戦です。",
      "天界大戦では、神々がそれぞれの管理する星から選んだ人類代表同士が戦います。神自身も王として盤上へ降ります。",
      "盤上へ降りた神は本来の神性を封じられ、神としての力を人類規模の魔法へ変換した状態で戦います。",
      "戦いの結果は神々のランキングへ反映され、最終的に王への挑戦権へとつながります。",
    ],
  },
  {
    category: "CONFLICT",
    title: "神々と外敵が直接戦わない理由",
    paragraphs: [
      "外敵は概念的な存在である神々を直接攻撃できません。一方で、神々も外敵を直接排除することを禁じられています。",
      "外敵には学習する力があり、神が不用意に干渉すると、外敵へ神性を与えてしまう危険があるためです。",
      "そこで外敵は、天界大戦へ参加する人類代表を狙います。人類代表を失わせて儀式を破綻させ、太陽の封印更新を止めることが目的です。",
    ],
  },
];

const pageLinks = [
  {
    label: "世界観",
    link: "/world/mystiriarum-eredia/overview",
    active: true,
  },
  {
    label: "地理と国家",
    link: "/world/mystiriarum-eredia/geography",
    active: false,
  },
  {
    label: "社会と生活・娯楽",
    link: "/world/mystiriarum-eredia/life",
    active: false,
  },
  {
    label: "組織・制度",
    link: "/world/mystiriarum-eredia/systems",
    active: false,
  },
  {
    label: "脅威",
    link: "/world/mystiriarum-eredia/threats",
    active: false,
  },
  {
    label: "魔法",
    link: "/world/mystiriarum-eredia/magic",
    active: false,
  },
  {
    label: "用語集",
    link: "/world/mystiriarum-eredia/glossary",
    active: false,
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="description"
      content="魔法が人々の暮らしに根付いた世界、ミスティリアルム・エレディアの世界観を紹介します。"
    />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>世界観 | ミスティリアルム・エレディア | 神白 凛</title>
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">{siteName}</a>

      <nav class="nav" aria-label="メインメニュー">
        <a href="/#profile">プロフィール</a>
        <a href="/#topics">トピック</a>
        <a href="/#youtube">YouTube</a>
        <a href="/#works">作品集</a>
        <a href="/#contact">コンタクト</a>
      </nav>
    </header>

    <nav class="world-navigation" aria-label="設定資料メニュー">
      <a class="world-home-link" href="/world/mystiriarum-eredia">
        ミスティリアルム・エレディア
      </a>

      <div class="world-navigation-links">
        {
          pageLinks.map((page) => (
            <a
              class:list={["world-navigation-link", { active: page.active }]}
              href={page.link}
              aria-current={page.active ? "page" : undefined}
            >
              {page.label}
            </a>
          ))
        }
      </div>
    </nav>

    <main>
      <section class="page-hero">
        <div class="hero-decoration" aria-hidden="true">界</div>

        <div class="hero-inner">
          <p class="hero-label">WORLD OVERVIEW</p>

          <h1>世界観</h1>

          <p class="hero-world-name">
            ミスティリアルム・エレディア
          </p>

          <p class="hero-lead">
            魔法が暮らしを豊かにしながら、
            未知の脅威とも隣り合わせにある世界。
          </p>

          <div class="hero-actions">
            <a class="button primary" href="#world-overview">
              世界観を読む
            </a>

            <a class="button" href="/world/mystiriarum-eredia">
              設定資料へ戻る
            </a>
          </div>
        </div>
      </section>

      <section class="section" id="world-overview">
        <div class="section-heading">
          <p>ABOUT THE WORLD</p>
          <h2>魔法が当たり前の世界</h2>
        </div>

        <article class="overview-card">
          <div class="overview-content">
            <p class="small-label">MYSTIRIARUM EREDIA</p>

            <h3>この星の名は<br />「ミスティリアルム・エレディア」</h3>

            <p>
              この星では、魔法は特別なものではありません。
              人々が生まれながらに持ち、誰もが扱える力として、
              社会や日々の暮らしに深く浸透しています。
            </p>

            <p>
              魔法は戦いのためだけに存在するものではなく、
              生活、物流、医療、治安維持など、
              人々の生活を支えるインフラとして広く用いられています。
            </p>

            <p>
              一方で、この世界には人間だけでなく、
              魔法を扱う魔物も存在しています。
              文明の外縁や未知の領域には、
              今も数多くの危険が潜んでいます。
            </p>

            <p>
              ミスティリアルム・エレディアは、
              魔法が暮らしを豊かにしながら、
              同時に危険とも隣り合わせにある
              「魔法が当たり前の世界」です。
            </p>
          </div>
        </article>
      </section>

      <section class="section">
        <div class="section-heading">
          <p>WORLD FEATURES</p>
          <h2>世界の特徴</h2>
        </div>

        <div class="feature-grid">
          {
            worldFeatures.map((feature) => (
              <article class="feature-card">
                <div class="feature-number" aria-hidden="true">
                  {feature.number}
                </div>

                <div class="feature-card-top">
                  <p>{feature.category}</p>
                </div>

                <div class="feature-card-content">
                  <h3>{feature.title}</h3>
                  <p>{feature.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section spoiler-section">
        <div class="section-heading">
          <p>SECRET OF THE WORLD</p>
          <h2>世界の真相</h2>
        </div>

        <div class="spoiler-warning">
          <p class="small-label">SPOILER WARNING</p>
          <h3>ここから先はネタバレを含みます</h3>

          <p>
            世界の成り立ちや神々、太陽、外敵など、
            物語の根幹に関わる設定が記載されています。
          </p>
        </div>

        <details class="spoiler-details">
          <summary>
            <span class="summary-label">
              ネタバレ設定を開く
            </span>

            <span class="summary-icon" aria-hidden="true">
              ＋
            </span>
          </summary>

          <div class="spoiler-content">
            {
              spoilerSections.map((section, index) => (
                <article class="secret-card">
                  <div class="secret-card-heading">
                    <div>
                      <p>{section.category}</p>
                      <h3>{section.title}</h3>
                    </div>

                    <span aria-hidden="true">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                  </div>

                  <div class="secret-card-body">
                    {
                      section.paragraphs.map((paragraph) => (
                        <p>{paragraph}</p>
                      ))
                    }
                  </div>
                </article>
              ))
            }
          </div>
        </details>
      </section>

      <section class="section page-navigation-section">
        <div class="page-navigation-card">
          <a
            class="page-navigation-item previous"
            href="/world/mystiriarum-eredia"
          >
            <span class="page-navigation-direction">
              ← BACK
            </span>

            <strong>設定資料一覧</strong>
          </a>

          <span class="page-navigation-divider" aria-hidden="true"></span>

          <a
            class="page-navigation-item next"
            href="/world/mystiriarum-eredia/geography"
          >
            <span class="page-navigation-direction">
              NEXT →
            </span>

            <strong>地理と国家</strong>
          </a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <p>© 神白 凛</p>
    </footer>
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Kaisei+Tokumin:wght@400;500;700;800&family=Yuji+Syuku&display=swap");

  :root {
    --bg: #fffafb;
    --bg-soft: #fff1f5;
    --paper: #ffffff;

    --line: rgba(238, 143, 170, 0.34);

    --sakura: #f3a9bd;
    --sakura-soft: #ffd6e1;
    --sakura-deep: #dd6f94;
    --sakura-strong: #f08aaa;

    --text: #3a2630;
    --muted: #7b5c68;
    --muted-light: #9b7d88;

    --shadow: rgba(179, 92, 119, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    margin: 0;
    color: var(--text);
    font-family:
      "Kaisei Tokumin",
      "Yu Mincho",
      "Hiragino Mincho ProN",
      "Noto Serif JP",
      serif;
    line-height: 1.9;
    background:
      radial-gradient(
        circle at 18% 8%,
        rgba(255, 198, 214, 0.72),
        transparent 34%
      ),
      radial-gradient(
        circle at 82% 4%,
        rgba(255, 224, 233, 0.85),
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 92%,
        rgba(243, 169, 189, 0.42),
        transparent 38%
      ),
      linear-gradient(
        180deg,
        #fffafb 0%,
        #fff4f7 48%,
        #fffefe 100%
      );
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(
        rgba(238, 143, 170, 0.08) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(238, 143, 170, 0.08) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
    mask-image: linear-gradient(
      to bottom,
      black,
      transparent 82%
    );
  }

  body::after {
    content: "✦ ✧ ✦";
    position: fixed;
    right: 5vw;
    bottom: 4vh;
    z-index: -1;
    pointer-events: none;
    color: rgba(240, 138, 170, 0.16);
    font-size: clamp(48px, 9vw, 120px);
    letter-spacing: 0.12em;
    transform: rotate(-8deg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 5vw;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 250, 251, 0.9);
    box-shadow: 0 10px 30px rgba(238, 143, 170, 0.08);
    backdrop-filter: blur(14px);
  }

  .logo {
    color: var(--sakura-deep);
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.14em;
  }

  .nav {
    display: flex;
    gap: 24px;
    font-size: 14px;
    letter-spacing: 0.12em;
  }

  .nav a {
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .nav a:hover {
    color: var(--sakura-deep);
  }

  .world-navigation {
    position: sticky;
    top: 84px;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 12px 5vw;
    border-bottom: 1px solid rgba(238, 143, 170, 0.24);
    background: rgba(255, 250, 251, 0.92);
    backdrop-filter: blur(14px);
  }

  .world-home-link {
    flex-shrink: 0;
    color: var(--sakura-deep);
    font-size: 13px;
    font-weight: 700;
  }

  .world-navigation-links {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .world-navigation-link {
    flex-shrink: 0;
    padding: 6px 12px;
    border-radius: 999px;
    color: var(--muted);
    font-size: 12px;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }

  .world-navigation-link:hover,
  .world-navigation-link.active {
    color: var(--sakura-deep);
    background: rgba(255, 214, 225, 0.62);
  }

  main {
    overflow: hidden;
  }

  .page-hero {
    position: relative;
    min-height: 68vh;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 110px 5vw 90px;
    border-bottom: 1px solid var(--line);
  }

  .page-hero::before {
    content: "";
    position: absolute;
    width: min(640px, 72vw);
    aspect-ratio: 1;
    border: 1px solid rgba(240, 138, 170, 0.28);
    border-radius: 50%;
    background: rgba(255, 214, 225, 0.16);
    transform: rotate(18deg);
  }

  .page-hero::after {
    content: "";
    position: absolute;
    width: min(360px, 44vw);
    aspect-ratio: 1;
    border: 1px solid rgba(221, 111, 148, 0.26);
    background: rgba(255, 255, 255, 0.26);
    transform: rotate(45deg);
  }

  .hero-decoration {
    position: absolute;
    color: rgba(240, 138, 170, 0.11);
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(190px, 32vw, 420px);
    line-height: 1;
    user-select: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: min(920px, 90vw);
    text-align: center;
  }

  .hero-label,
  .section-heading > p,
  .small-label {
    margin: 0;
    color: var(--sakura-deep);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 18px 0 10px;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(66px, 12vw, 136px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.1em;
    text-shadow: 0 8px 34px rgba(240, 138, 170, 0.18);
  }

  .hero-world-name {
    margin: 0 0 22px;
    color: var(--sakura-deep);
    font-size: clamp(18px, 3vw, 28px);
    letter-spacing: 0.1em;
  }

  .hero-lead {
    max-width: 700px;
    margin: 0 auto;
    color: var(--muted);
    font-size: 18px;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .button {
    min-width: 150px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 22px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--sakura-deep);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 12px 32px rgba(238, 143, 170, 0.12);
    font-weight: 700;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: var(--sakura-strong);
    background: #ffffff;
    box-shadow: 0 16px 40px rgba(238, 143, 170, 0.2);
  }

  .button.primary {
    color: #ffffff;
    border-color: transparent;
    background: linear-gradient(
      135deg,
      var(--sakura-strong),
      var(--sakura-deep)
    );
  }

  .section {
    width: min(1100px, 90vw);
    margin: 0 auto;
    padding: 110px 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 34px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--line);
  }

  .section-heading h2 {
    max-width: 760px;
    margin: 0;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.06em;
    text-align: right;
  }

  .overview-card {
    padding: clamp(30px, 5vw, 58px);
    border: 1px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(
        135deg,
        rgba(255, 214, 225, 0.72),
        transparent 46%
      ),
      rgba(255, 255, 255, 0.88);
    box-shadow: 0 24px 80px var(--shadow);
  }

  .overview-content {
    max-width: 850px;
  }

  .overview-content h3 {
    margin: 10px 0 26px;
    font-family:
      "Yuji Syuku",
      "Kaisei Tokumin",
      serif;
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 400;
    line-height: 1.5;
  }

  .overview-content > p {
    color: var(--muted);
  }

  .overview-content > p:not(.small-label) {
    margin: 0 0 20px;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .feature-card {
    position: relative;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(
        145deg,
        rgba(255, 198, 214, 0.68),
        transparent 48%
      ),
