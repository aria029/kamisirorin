---
const works = [
  {
    title: "YouTube作品サンプル",
    category: "YouTube",
    description: "動画作品の紹介文をここに書きます。YouTubeの動画リンクや埋め込みを載せる予定です。",
    url: "https://www.youtube.com/",
  },
  {
    title: "世界観設定サンプル",
    category: "World",
    description: "世界観、キャラクター、用語、設定資料などの文章作品をまとめます。",
    url: "/world",
  },
  {
    title: "外部リンクサンプル",
    category: "Link",
    description: "他のサイト、SNS、関連プロジェクトへのリンクをまとめます。",
    url: "https://example.com/",
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="kamisirorinの作品一覧ページです。YouTube作品、世界観設定、文章作品、外部リンクをまとめています。"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Works | kamisirorin</title>
  </head>

  <body>
    <header class="header">
      <a class="logo" href="/">kamisirorin</a>

      <nav class="nav">
        <a href="/">Home</a>
        <a href="/works">Works</a>
        <a href="/world">World</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <p class="label">Works</p>
        <h1>作品一覧</h1>
        <p class="lead">
          YouTube作品、世界観の設定資料、文章作品、外部リンクなどをまとめています。
        </p>
      </section>

      <section class="works">
        {works.map((work) => (
          <article class="work-card">
            <p class="category">{work.category}</p>
            <h2>{work.title}</h2>
            <p>{work.description}</p>
            <a href={work.url}>詳しく見る →</a>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #111;
    color: #f5f5f5;
    line-height: 1.7;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px;
    border-bottom: 1px solid #333;
  }

  .logo {
    font-weight: 800;
    font-size: 20px;
  }

  .nav {
    display: flex;
    gap: 16px;
    font-size: 14px;
  }

  .nav a {
    color: #ccc;
  }

  .nav a:hover {
    color: #fff;
  }

  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 24px;
  }

  .hero {
    padding: 64px 0 40px;
  }

  .label {
    color: #aaa;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 13px;
  }

  h1 {
    font-size: clamp(40px, 8vw, 72px);
    line-height: 1.05;
    margin: 16px 0;
  }

  .lead {
    max-width: 640px;
    color: #d0d0d0;
    font-size: 18px;
  }

  .works {
    display: grid;
    gap: 16px;
    padding-bottom: 80px;
  }

  .work-card {
    border: 1px solid #333;
    border-radius: 20px;
    padding: 24px;
    background: #181818;
  }

  .work-card h2 {
    margin: 8px 0;
  }

  .work-card p {
    color: #cfcfcf;
  }

  .category {
    color: #aaa;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 13px;
  }

  .work-card a {
    display: inline-block;
    margin-top: 12px;
    font-weight: 700;
    color: #fff;
  }

  @media (max-width: 700px) {
    .header {
      display: block;
    }

    .nav {
      margin-top: 16px;
      flex-wrap: wrap;
    }
  }
</style>