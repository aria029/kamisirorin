---
const worlds = [
  {
    number: "01",
    label: "WORLD & STORY",
    title: "ミスティリアルム・エレディア",
    reading: "",
    description:
      "世界の歴史・文化・用語・物語の背景を文章にまとめた世界観設定です。",
    href: "/world/mystiriarum-eredia",
  },
  {
    number: "02",
    label: "WORLD & STORY",
    title: "桜花の国",
    reading: "おうかのくに",
    description:
      "世界の歴史・文化・用語・物語の背景を文章にまとめた世界観設定です。",
    href: "/world/ouka-no-kuni",
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="description"
      content="神白 凛が制作している世界観・物語設定の一覧です。"
    />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>世界観・物語設定 | 神白 凛</title>
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">神白 凛</a>

      <nav class="nav">
        <a href="/">ホーム</a>
        <a href="/#profile">プロフィール</a>
        <a href="/#youtube">YouTube</a>
        <a href="/#works">作品集</a>
        <a href="/#contact">コンタクト</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-mark" aria-hidden="true">世</div>

        <div class="hero-content">
          <p class="hero-label">WORLD BUILDING</p>

          <h1>世界観・物語設定</h1>

          <p class="hero-description">
            小説や漫画の舞台となる世界を考え、歴史・文化・用語・物語の背景をまとめています。
          </p>
        </div>
      </section>

      <section class="world-section">
        <div class="section-heading">
          <div>
            <p>WORLD LIST</p>
            <h2>世界一覧</h2>
          </div>

          <span>創作している世界の記録</span>
        </div>

        <div class="world-list">
          {
            worlds.map((world) => (
              <a class="world-card" href={world.href}>
                <div class="world-card-decoration" aria-hidden="true">
                  ✿
                </div>

                <div class="world-card-number" aria-hidden="true">
                  {world.number}
                </div>

                <div class="world-card-content">
                  <p class="world-label">{world.label}</p>

                  {
                    world.reading ? (
                      <div class="world-title-area">
                        <p class="world-reading">{world.reading}</p>
                        <h3>{world.title}</h3>
                      </div>
                    ) : (
                      <h3>{world.title}</h3>
                    )
                  }

                  <p class="world-description">{world.description}</p>

                  <div class="world-card-footer">
                    <span>世界観・物語設定を見る</span>
                    <span class="arrow" aria-hidden="true">→</span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>

    <footer class="footer">
      <p>© 神白 凛</p>
    </footer>
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Kaisei+Tokumin:wght@400;500;700;800&family=Yuji+Syuku&display=swap");

  :root {
    --background: #fff9fb;
    --background-soft: #fff0f5;
    --paper: rgba(255, 255, 255, 0.9);

    --line: rgba(238, 143, 170, 0.36);

    --sakura: #f3a9bd;
    --sakura-light: #ffd7e2;
    --sakura-deep: #df7397;
    --sakura-strong: #ef86a9;

    --text: #3a2630;
    --muted: #82636e;
    --muted-light: #a1848e;

    --shadow: rgba(179, 92, 119, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--text);
    font-family:
      "Kaisei Tokumin",
      "Yu Mincho",
      "Hiragino Mincho ProN",
      "Noto Serif JP",
      serif;
    line-height: 1.8;
    background:
      radial-gradient(
        circle at 8% 5%,
        rgba(255, 203, 218, 0.7),
        transparent 30%
      ),
      radial-gradient(
        circle at 92% 18%,
        rgba(255, 225, 234, 0.85),
        transparent 34%
      ),
      linear-gradient(
        180deg,
        var(--background) 0%,
        var(--background-soft) 100%
      );
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(
        rgba(238, 143, 170, 0.07) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(238, 143, 170, 0.07) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
  }

  body::after {
    content: "✦";
    position: fixed;
    right: -28px;
    bottom: 40px;
    z-index: -1;
    pointer-events: none;
    color: rgba(239, 134, 169, 0.16);
    font-size: 130px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 21px 5vw;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 249, 251, 0.88);
    backdrop-filter: blur(14px);
    box-shadow: 0 10px 32px rgba(238, 143, 170, 0.08);
  }

  .logo {
    color: var(--sakura-deep);
    font-family: "Yuji Syuku", "Kaisei Tokumin", serif;
    font-size: 26px;
    letter-spacing: 0.14em;
  }

  .nav {
    display: flex;
    gap: 24px;
    color: var(--muted);
    font-size: 14px;
    letter-spacing: 0.08em;
  }

  .nav a {
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .nav a:hover {
    color: var(--sakura-deep);
  }

  .hero {
    position: relative;
    min-height: 480px;
    display: grid;
    place-items: center;
    padding: 90px 5vw 80px;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .hero::before {
    content: "";
    position: absolute;
    width: 480px;
    height: 480px;
    border: 1px solid rgba(239, 134, 169, 0.28);
    border-radius: 999px;
    background: rgba(255, 215, 226, 0.18);
  }

  .hero-mark {
    position: absolute;
    color: rgba(239, 134, 169, 0.12);
    font-family: "Yuji Syuku", "Kaisei Tokumin", serif;
    font-size: clamp(190px, 28vw, 390px);
    line-height: 1;
    user-select: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
  }

  .hero-label,
  .section-heading p,
  .world-label {
    margin: 0;
    color: var(--sakura-deep);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2em;
  }

  h1 {
    margin: 16px 0 20px;
    font-family: "Yuji Syuku", "Kaisei Tokumin", serif;
    font-size: clamp(54px, 9vw, 112px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.08em;
  }

  .hero-description {
    max-width: 720px;
    margin: 0 auto;
    color: var(--muted);
    font-size: 17px;
  }

  .world-section {
    width: min(1100px, 90vw);
    margin: 0 auto;
    padding: 100px 0 120px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 34px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .section-heading h2 {
    margin: 4px 0 0;
    font-family: "Yuji Syuku", "Kaisei Tokumin", serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.08em;
  }

  .section-heading > span {
    color: var(--muted-light);
    font-size: 14px;
  }

  .world-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .world-card {
    position: relative;
    min-height: 360px;
    display: block;
    overflow: hidden;
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(
        115deg,
        rgba(255, 210, 222, 0.78),
        rgba(255, 255, 255, 0.93) 54%
      );
    box-shadow: 0 22px 64px var(--shadow);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .world-card:hover {
    transform: translateY(-5px);
    border-color: rgba(223, 115, 151, 0.58);
    box-shadow: 0 30px 76px rgba(179, 92, 119, 0.22);
  }

  .world-card-decoration {
    position: absolute;
    top: 34px;
    right: 34px;
    color: rgba(223, 115, 151, 0.24);
    font-size: 58px;
    line-height: 1;
  }

  .world-card-number {
    position: absolute;
    right: 44px;
    bottom: 18px;
    color: rgba(223, 115, 151, 0.08);
    font-family: "Kaisei Tokumin", serif;
    font-size: clamp(130px, 18vw, 210px);
    font-weight: 400;
    line-height: 1;
    user-select: none;
  }

  .world-card-content {
    position: relative;
    z-index: 1;
    min-height: 300px;
    display: flex;
    flex-direction: column;
  }

  .world-card h3 {
    max-width: 830px;
    margin: auto 0 16px;
    font-family: "Yuji Syuku", "Kaisei Tokumin", serif;
    font-size: clamp(42px, 6vw, 70px);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 0.08em;
  }

  .world-title-area {
    margin-top: auto;
  }

  .world-title-area h3 {
    margin-top: 0;
  }

  .world-reading {
    margin: 0 0 -2px;
    color: var(--sakura-deep);
    font-size: 18px;
    letter-spacing: 0.5em;
  }

  .world-description {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
  }

  .world-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 30px;
    padding-top: 18px;
    border-top: 1px solid rgba(238, 143, 170, 0.3);
    color: var(--sakura-deep);
    font-size: 14px;
    font-weight: 700;
  }

  .arrow {
    font-size: 24px;
    transition: transform 0.2s ease;
  }

  .world-card:hover .arrow {
    transform: translateX(5px);
  }

  .footer {
    padding: 32px 5vw;
    border-top: 1px solid var(--line);
    color: var(--muted-light);
    text-align: center;
    background: rgba(255, 250, 251, 0.72);
  }

  .footer p {
    margin: 0;
  }

  @media (max-width: 780px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav {
      width: 100%;
      gap: 18px;
      padding-bottom: 4px;
      overflow-x: auto;
    }

    .hero {
      min-height: 410px;
    }

    .section-heading {
      display: block;
    }

    .section-heading > span {
      display: block;
      margin-top: 10px;
    }

    .world-card {
      min-height: 330px;
      padding: 26px;
    }

    .world-card-content {
      min-height: 276px;
    }

    .world-card-decoration {
      top: 24px;
      right: 24px;
      font-size: 48px;
    }

    .world-card-number {
      right: 24px;
    }
  }

  @media (max-width: 520px) {
    .hero {
      place-items: end start;
      text-align: left;
    }

    .hero-content {
      text-align: left;
    }

    .hero-description {
      margin: 0;
    }

    .world-card {
      min-height: 310px;
      border-radius: 24px;
    }

    .world-card h3 {
      font-size: 38px;
    }

    .world-reading {
      font-size: 14px;
    }
  }
</style>